#!/usr/bin/env bash
# post-checkout hook: warns when the checked-out branch will trigger
# 3rd-party package regeneration on Azure Pipelines.
#
# Install this hook by running once in the repo root:
#   git config core.hooksPath .githooks
#
# Arg 1: previous HEAD, arg 2: new HEAD, arg 3: 1=branch checkout 0=file checkout

# Only run on branch checkouts, not file-level checkouts.
[ "$3" = "1" ] || exit 0

branch=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0

if echo "$branch" | grep -q -- "-rebuild-pkgs$"; then
    echo ""
    echo "================================================================"
    echo "  WARNING: 3rd-PARTY PACKAGE REGENERATION WILL BE TRIGGERED"
    echo "================================================================"
    echo ""
    echo "  This branch ends with '-rebuild-pkgs':"
    echo "    $branch"
    echo ""
    echo "  Opening a Pull Request from this branch will automatically"
    echo "  launch the Azure Pipelines 'Py 3rd-Party Pkgs' jobs across"
    echo "  all Python versions (3.7, 3.9, 3.10, 3.11, 3.13) and all"
    echo "  platforms (Linux, Mac, Windows). This takes significant CI"
    echo "  time and will commit updated packages to a new branch:"
    echo "    ${branch}-automated  (will NOT trigger regeneration)"
    echo ""
    echo "  Only proceed if you intentionally need to regenerate"
    echo "  3rd-party packages. See README.md for details."
    echo ""
    echo "================================================================"
    echo ""
fi
